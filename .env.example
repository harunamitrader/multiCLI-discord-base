# 基本設定（環境ごとの値のみ）
PORT=3087
HOST=127.0.0.1
DATA_DIR=./data
# 添付ファイルだけは repo 外へ逃がすと、CLI の ignore に引っかかりにくいです。
UPLOADS_DIR=

# Discord 設定
# DISCORD_ALLOWED_GUILD_IDS は必ず 1 つだけ指定します。
# DISCORD_ALLOWED_CHANNEL_IDS を空欄にすると、
# 許可されたサーバー内のテキストチャンネル一覧から UI で選べます。
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_ALLOWED_CHANNEL_IDS=

# 任意のファイル監視ログ設定（watch を使う場合のみ）
FILE_WATCH_ENABLED=false
FILE_WATCH_ROOT=
FILE_LOG_CHANNEL_ID=

# sensitive runtime API を loopback 以外から使う場合のみ設定
MULTICLI_API_TOKEN=
MULTICLI_API_ALLOW_LOOPBACK=true

# drift warning のしきい値（任意）
MULTICLI_DRIFT_RUNNING_SILENCE_MS=120000
MULTICLI_DRIFT_READY_SILENCE_MS=900000
MULTICLI_DRIFT_POLL_MS=15000

# その他の設定は config\*.json へ移動
# - config\cli-settings.json
# - config\agents.json
# - config\app-settings.json
