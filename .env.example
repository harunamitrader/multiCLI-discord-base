# 基本設定
PORT=3087
HOST=127.0.0.1

# ローカル Codex CLI 設定
CODEX_COMMAND=codex
CODEX_WORKDIR=C:\Users\your-name\Desktop\codex
CODEX_ENABLE_SEARCH=true
CODEX_BYPASS_APPROVALS_AND_SANDBOX=true
DATA_DIR=./data

# Discord 設定
# DISCORD_ALLOWED_GUILD_IDS は必ず 1 つだけ指定します。
# DISCORD_ALLOWED_CHANNEL_IDS を空欄にすると、
# 許可されたサーバー内のテキストチャンネル一覧から UI で選べます。
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_STATUS_UPDATES=true

# 任意のファイル監視ログ設定
FILE_WATCH_ENABLED=false
FILE_WATCH_ROOT=
FILE_LOG_CHANNEL_ID=
FILE_WATCH_DEBOUNCE_MS=1000
FILE_WATCH_MAX_ATTACHMENT_BYTES=8388608
FILE_WATCH_IGNORE=.git,node_modules,dist,.next,coverage
