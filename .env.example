# 基本設定（環境ごとの値のみ）
PORT=3087
HOST=127.0.0.1
DATA_DIR=./data

# Discord 設定
# DISCORD_ALLOWED_GUILD_IDS は必ず 1 つだけ指定します。
# DISCORD_ALLOWED_CHANNEL_IDS を空欄にすると、
# 許可されたサーバー内のテキストチャンネル一覧から UI で選べます。
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_ALLOWED_CHANNEL_IDS=

# 任意のファイル監視ログ設定（watch を使う場合のみ）
FILE_WATCH_ENABLED=false
FILE_WATCH_ROOT=
FILE_LOG_CHANNEL_ID=

# その他の設定は config\*.json へ移動
# - config\cli-settings.json
# - config\agents.json
# - config\app-settings.json
